# Upload this visible file to the server, rename it to .env, then edit CHANGE values.
# Compose reads this one root .env for MariaDB, backend, and frontend.
APP_ENV=production

FRONTEND_PORT=6222
BACKEND_PORT=6555
MARIADB_PORT=3307

# Keep both services local to the Docker host. The frontend nginx proxies /api internally.
BACKEND_BIND_ADDRESS=127.0.0.1
MARIADB_BIND_ADDRESS=127.0.0.1

MARIADB_DATABASE=glavk
MARIADB_USER=glavk_user
MARIADB_PASSWORD=CHANGE-db-password
MARIADB_ROOT_PASSWORD=CHANGE-root-password

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-admin-password
ADMIN_PASSWORD_HASH=
AUTH_TOKEN_TTL_DAYS=30

# Leave the encryption keys empty. The backend generates them once and stores them
# in the persistent backend_data volume on first startup.
AUTH_SECRET_KEY=
CREDENTIAL_ENCRYPTION_KEY=
TRANSPORT_PRIVATE_KEY_B64=
GLAVK_RUNTIME_SECRETS_FILE=/app/data/runtime-secrets.env

# Same-origin frontend requests do not require CORS.
CORS_ORIGINS=
SCREENSHOT_DIR=/app/data/screenshots
SCREENSHOT_ALLOW_PRIVATE_NETWORKS=false
