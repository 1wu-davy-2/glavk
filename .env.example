APP_ENV=production

FRONTEND_PORT=6222
BACKEND_PORT=6555
MARIADB_PORT=3307

MARIADB_DATABASE=glavk
MARIADB_USER=glavk_user
MARIADB_PASSWORD=replace-with-a-strong-database-password
MARIADB_ROOT_PASSWORD=replace-with-a-strong-root-password

DATABASE_URL=mysql+pymysql://glavk_user:replace-with-a-strong-database-password@mariadb:3306/glavk?charset=utf8mb4
AUTH_SECRET_KEY=replace-with-a-random-string-at-least-32-characters
AUTH_TOKEN_TTL_DAYS=30
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-valid-fernet-key

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-the-first-admin-password
ADMIN_PASSWORD_HASH=
CORS_ORIGINS=http://localhost:6222,http://127.0.0.1:6222
