# Copy this file to .env on the server, then edit only the values marked CHANGE.
APP_ENV=production

# CHANGE: an address that browsers can reach. Do not use 0.0.0.0 here.
SERVER_IP=192.168.1.100
FRONTEND_PORT=6222
BACKEND_PORT=6555
MARIADB_PORT=3307
MARIADB_BIND_ADDRESS=127.0.0.1

MARIADB_DATABASE=glavk
MARIADB_USER=glavk_user
MARIADB_PASSWORD=CHANGE-db-password
MARIADB_ROOT_PASSWORD=CHANGE-root-password

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-admin-password
ADMIN_PASSWORD_HASH=
AUTH_TOKEN_TTL_DAYS=30

# Derived values: keep these lines unless you need a custom reverse proxy.
VITE_API_BASE_URL=
CORS_ORIGINS=

# Leave the three key values empty. The backend generates them once and stores
# them in the persistent backend_data volume before starting the API.
AUTH_SECRET_KEY=
CREDENTIAL_ENCRYPTION_KEY=
TRANSPORT_PRIVATE_KEY_B64=
GLAVK_RUNTIME_SECRETS_FILE=/app/data/runtime-secrets.env

SCREENSHOT_DIR=/app/data/screenshots
SCREENSHOT_ALLOW_PRIVATE_NETWORKS=false
